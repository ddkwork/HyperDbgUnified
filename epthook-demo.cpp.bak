/**
 * @file epthook-demo.cpp
 * @brief HyperDbg Hook Demo - EPT Hook + CPUID 伪造
 *
 * 全部使用导出的用户模式 API，不调用未导出的内部函数
 *
 * 核心 API：
 *   hyperdbg_u_run_command()    - 执行 HyperDbg 命令 (如 !epthook2, !cpuid)
 *   hyperdbg_u_run_script()     - 执行脚本表达式 (纯 C 调用，无命令行)
 *   hyperdbg_u_eval_expression()- 求值表达式，获取符号地址
 *   hyperdbg_u_read_memory()    - 读取内存
 *   hyperdbg_u_write_memory()   - 写入内存
 *   hyperdbg_u_read_all_registers()  - 读取寄存器
 *   hyperdbg_u_read_target_register() - 读取单个寄存器
 *   hyperdbg_u_write_target_register() - 写入单个寄存器
 *
 * 注意：SendEventToKernel / RegisterActionToEvent 是内部函数，未导出到用户模式
 *       用户模式只能通过 run_command / run_script 注册事件
 *
 * NtDeviceIoControlFile x64 参数布局（函数入口，return address 已压栈）：
 *   RCX = FileHandle, RDX = Event, R8 = ApcRoutine, R9 = ApcContext
 *   @rsp+0x30 = IoStatusBlock
 *   @rsp+0x38 = IoControlCode
 *   @rsp+0x40 = InputBuffer
 *   @rsp+0x48 = InputBufferLength
 *   @rsp+0x50 = OutputBuffer
 *   @rsp+0x58 = OutputBufferLength
 */

#include <Windows.h>
#include <cstdio>
#include <cstring>
#include <string>

#include "SDK/HyperDbgSdk.h"
#include "SDK/imports/user/HyperDbgLibImports.h"

#define TARGET_PROCESS_NAME "svchost.exe"

//
// Global flag for Ctrl+C graceful exit
//
static volatile BOOL g_ShouldExit = FALSE;

//
// Ctrl+C handler - 设置退出标志，让 fgets 循环退出
//
BOOL WINAPI
ConsoleCtrlHandler(DWORD ctrlType)
{
    if (ctrlType == CTRL_C_EVENT || ctrlType == CTRL_BREAK_EVENT)
    {
        g_ShouldExit = TRUE;
        printf("\n[*] Ctrl+C received, exiting...\n");
        fflush(stdout);
        return TRUE;
    }
    return FALSE;
}

//
// Message callback - HyperDbg 内部 IrpBasedBufferThread 收到内核消息后
// 通过 ShowMessages -> g_MessageHandler 调用此回调
//
int
hyperdbg_message_callback(const char * Text)
{
    printf("%s", Text);
    fflush(stdout);
    return 0;
}

//
// 辅助函数：执行命令并打印调试信息
//
static INT
RunCommandDebug(const char * cmd, const char * desc)
{
    printf("[DBG] Executing: %s\n", desc ? desc : cmd);
    fflush(stdout);

    INT ret = hyperdbg_u_run_command((CHAR *)cmd);

    printf("[DBG] Command returned: %d\n", ret);
    fflush(stdout);
    return ret;
}

//
// Load HyperDbg in VMI mode
//
int
LoadHyperDbg()
{
    char CpuId[13] = {0};

    hyperdbg_u_read_vendor_string(CpuId);
    printf("[*] CPU vendor: %s\n", CpuId);

    if (strcmp(CpuId, "GenuineIntel") != 0)
    {
        printf("[-] Requires Intel VT-x\n");
        return 1;
    }

    if (!hyperdbg_u_detect_vmx_support())
    {
        printf("[-] VMX not supported\n");
        return 1;
    }
    printf("[+] VMX supported\n");

    //
    // 设置消息回调 (必须在 install_kd_driver 之前设置,
    // 因为 HyperDbgCreateHandleFromKdModule 会启动 IrpBasedBufferThread)
    //
    hyperdbg_u_set_text_message_callback(hyperdbg_message_callback);

    printf("[*] Installing driver...\n");
    fflush(stdout);
    if (hyperdbg_u_install_kd_driver() == 1)
    {
        printf("[-] Install driver failed\n");
        return 1;
    }

    printf("[*] Loading VMM...\n");
    fflush(stdout);
    if (hyperdbg_u_load_vmm() == 1)
    {
        printf("[-] Load VMM failed\n");
        hyperdbg_u_uninstall_kd_driver();
        return 1;
    }

    printf("[+] HyperDbg loaded\n");
    fflush(stdout);
    return 0;
}

//
// Unload HyperDbg
//
// 严格按照官方示例 (examples/user/hyperdbg_app/code/hyperdbg-app.cpp) 的卸载顺序。
// 不要在执行 events all clear！events all clear 会在 VMM 活跃时清空事件链表，
// 导致 unload_vmm 内部访问已清理的链表，内核状态损坏。
//
void
UnloadHyperDbg()
{
    printf("[*] Unloading...\n");
    fflush(stdout);
    hyperdbg_u_unload_vmm();
    hyperdbg_u_unload_kd();
    hyperdbg_u_stop_kd_driver();
    hyperdbg_u_uninstall_kd_driver();
    printf("[+] Unloaded\n");
    fflush(stdout);
}

// ============================================================
// EPT Hook - 使用 hyperdbg_u_run_command API
// ============================================================

/**
 * @brief 最简 EPT hook 测试 - 不过滤进程，打印所有 NtDeviceIoControlFile 调用
 *
 * 用于验证 !epthook2 是否能正常工作
 */
void
SetupEptHook_SimpleTest()
{
    printf("[*] Simple EPT hook test - no process filter\n");
    fflush(stdout);

    //
    // 最简脚本：只打印进程名和 IOCTL 码
    // 不使用 strcmp 过滤，验证 hook 机制本身是否工作
    //
    INT ret = RunCommandDebug(
        "!epthook2 nt!NtDeviceIoControlFile script { "
            "printf(\"[HOOK] %s pid:%x IOCTL:%x\\n\", pname, $pid, dd(@rsp+0x38)); "
        "}",
        "!epthook2 simple test (no filter)");

    if (ret != 0)
    {
        printf("[-] Simple hook failed (ret=%d), trying without script...\n", ret);
        fflush(stdout);

        //
        // 如果脚本版本失败，尝试不带脚本的纯断点版本
        //
        ret = RunCommandDebug(
            "!epthook2 nt!NtDeviceIoControlFile",
            "!epthook2 breakpoint (no script)");
    }
}

/**
 * @brief EPT hook NtDeviceIoControlFile + 读取 IOCTL 码和 buffer
 *
 * 使用 pid 过滤代替 strcmp，避免脚本中字符串匹配的问题
 */
void
SetupEptHook_IoctlRead(const char * pname, UINT32 pid)
{
    char cmd[4096];

    if (pid != 0)
    {
        //
        // 使用 pid 过滤（比 strcmp 更可靠）
        //
        snprintf(cmd, sizeof(cmd),
            "!epthook2 nt!NtDeviceIoControlFile pid %x script { "
                "printf(\"[IOCTL] %%s pid:%%x IOCTL:%%x InBuf:%%llx InLen:%%x OutBuf:%%llx OutLen:%%x\\n\", "
                    "pname, $pid, dd(@rsp+0x38), dq(@rsp+0x40), dd(@rsp+0x48), dq(@rsp+0x50), dd(@rsp+0x58)); "
            "}",
            pid);

        printf("[*] EPT hook + IOCTL read on %s (pid=0x%x)\n", pname, pid);
    }
    else
    {
        //
        // 无 pid，使用 strcmp 过滤
        // 注意：HyperDbg 脚本中 strcmp 的字符串字面量支持空格
        //
        snprintf(cmd, sizeof(cmd),
            "!epthook2 nt!NtDeviceIoControlFile script { "
                "if (strcmp(pname, \"%s\") == 0) { "
                    "printf(\"[IOCTL] %%s pid:%%x IOCTL:%%x InBuf:%%llx InLen:%%x OutBuf:%%llx OutLen:%%x\\n\", "
                        "pname, $pid, dd(@rsp+0x38), dq(@rsp+0x40), dd(@rsp+0x48), dq(@rsp+0x50), dd(@rsp+0x58)); "
                "} "
            "}",
            pname);

        printf("[*] EPT hook + IOCTL read on %s (no pid filter)\n", pname);
    }

    fflush(stdout);
    RunCommandDebug(cmd, "EPT hook IOCTL read");
}

/**
 * @brief EPT hook + 修改 output buffer (假硬盘序列号)
 */
void
SetupEptHook_FakeDiskSerial(const char * pname, UINT32 pid)
{
    char cmd[4096];

    if (pid != 0)
    {
        snprintf(cmd, sizeof(cmd),
            "!epthook2 nt!NtDeviceIoControlFile pid %x script { "
                "if (dd(@rsp+0x38) == 0x2d1400) { "
                    "printf(\"[DISK-QUERY] %%s pid:%%x OutBuf:%%llx OutLen:%%x\\n\", "
                        "pname, $pid, dq(@rsp+0x50), dd(@rsp+0x58)); "
                "} "
            "}",
            pid);
    }
    else
    {
        snprintf(cmd, sizeof(cmd),
            "!epthook2 nt!NtDeviceIoControlFile script { "
                "if (strcmp(pname, \"%s\") == 0) { "
                    "if (dd(@rsp+0x38) == 0x2d1400) { "
                        "printf(\"[DISK-QUERY] %%s pid:%%x OutBuf:%%llx OutLen:%%x\\n\", "
                            "pname, $pid, dq(@rsp+0x50), dd(@rsp+0x58)); "
                    "} "
                "} "
            "}",
            pname);
    }

    printf("[*] EPT hook + fake disk serial on %s\n", pname);
    fflush(stdout);
    RunCommandDebug(cmd, "EPT hook fake disk serial");
}

/**
 * @brief EPT hook + 修改 input buffer
 */
void
SetupEptHook_ModifyInputBuffer(const char * pname, UINT32 pid)
{
    char cmd[4096];

    if (pid != 0)
    {
        snprintf(cmd, sizeof(cmd),
            "!epthook2 nt!NtDeviceIoControlFile pid %x script { "
                "if (dd(@rsp+0x38) == 0x2d1400) { "
                    "if (dd(dq(@rsp+0x40)) == 0x0) { "
                        "printf(\"[MODIFY] %%s StorageDeviceProperty -> StorageAdapterProperty\\n\", pname); "
                        "ed(dq(@rsp+0x40), 0x1); "
                    "} "
                "} "
            "}",
            pid);
    }
    else
    {
        snprintf(cmd, sizeof(cmd),
            "!epthook2 nt!NtDeviceIoControlFile script { "
                "if (strcmp(pname, \"%s\") == 0) { "
                    "if (dd(@rsp+0x38) == 0x2d1400) { "
                        "if (dd(dq(@rsp+0x40)) == 0x0) { "
                            "printf(\"[MODIFY] %%s StorageDeviceProperty -> StorageAdapterProperty\\n\", pname); "
                            "ed(dq(@rsp+0x40), 0x1); "
                        "} "
                    "} "
                "} "
            "}",
            pname);
    }

    printf("[*] EPT hook + modify input buffer on %s\n", pname);
    fflush(stdout);
    RunCommandDebug(cmd, "EPT hook modify input buffer");
}

// ============================================================
// CPUID Hook - 使用 hyperdbg_u_run_command API
// ============================================================

void
SetupCpuidHook_Monitor()
{
    printf("[*] Setting up CPUID monitor hooks\n");
    fflush(stdout);

    RunCommandDebug(
        "!cpuid script { "
            "printf(\"[CPUID] leaf:%%x EAX:%%llx EBX:%%llx ECX:%%llx EDX:%%llx\\n\", "
                "@eax, @eax, @ebx, @ecx, @edx); "
        "}",
        "CPUID monitor (all leaves)");

    printf("[+] CPUID hooks registered\n");
    fflush(stdout);
}

void
SetupCpuidHook_FakeSerial()
{
    printf("[*] Setting up CPUID fake serial hooks\n");
    fflush(stdout);

    RunCommandDebug(
        "!cpuid 1 script { "
            "printf(\"[CPUID-1-FAKE] Signature: %%llx\\n\", @eax); "
        "}",
        "CPUID fake serial");

    printf("[+] CPUID fake serial hooks registered\n");
    fflush(stdout);
}

void
SetupTransparentMode(UINT32 pid)
{
    printf("[*] Enabling transparent mode for PID=%u\n", pid);
    fflush(stdout);

    if (hyperdbg_u_enable_transparent_mode(pid, NULL, TRUE))
    {
        printf("[+] Transparent mode enabled - CPUID will be faked\n");
    }
    else
    {
        printf("[-] Failed to enable transparent mode\n");
    }
    fflush(stdout);
}

// ============================================================
// 进程查找 - 通过进程名获取 PID
// ============================================================

#include <TlHelp32.h>

UINT32
FindProcessByName(const char * name)
{
    HANDLE snap = CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS, 0);
    if (snap == INVALID_HANDLE_VALUE)
        return 0;

    PROCESSENTRY32 pe = {0};
    pe.dwSize = sizeof(pe);

    if (Process32First(snap, &pe))
    {
        do
        {
            if (_stricmp(pe.szExeFile, name) == 0)
            {
                CloseHandle(snap);
                return pe.th32ProcessID;
            }
        } while (Process32Next(snap, &pe));
    }

    CloseHandle(snap);
    return 0;
}

// ============================================================
// 内存/寄存器 API - 纯 C 调用，GUI 直接用
// ============================================================

BOOL
ReadMemory(UINT64 address, UINT32 pid, BYTE * buffer, UINT32 size, UINT32 * bytesRead)
{
    DEBUGGER_READ_MEMORY_ADDRESS_MODE addrMode = DEBUGGER_READ_ADDRESS_MODE_64_BIT;
    return hyperdbg_u_read_memory(
        address,
        DEBUGGER_READ_VIRTUAL_ADDRESS,
        READ_FROM_KERNEL,
        pid,
        size,
        TRUE,
        &addrMode,
        buffer,
        bytesRead);
}

BOOL
WriteMemory(UINT64 address, UINT32 pid, BYTE * data, UINT32 size)
{
    return hyperdbg_u_write_memory(
        (PVOID)address,
        EDIT_VIRTUAL_MEMORY,
        pid,
        data,
        size);
}

UINT64
EvalSymbol(const char * expr, BOOLEAN * hasError)
{
    return hyperdbg_u_eval_expression((CHAR *)expr, hasError);
}

BOOL
RunScript(const char * script)
{
    return hyperdbg_u_run_script((CHAR *)script, TRUE);
}

// ============================================================
// 交互式命令循环
// ============================================================

void
ShowHelp()
{
    printf("\n=== HyperDbg Hook Demo Commands ===\n");
    printf("  test             - Simple EPT hook test (no filter)\n");
    printf("  hook1 [process]  - EPT hook + read IOCTL\n");
    printf("  hook2 [process]  - EPT hook + fake disk serial\n");
    printf("  hook3 [process]  - EPT hook + modify input buffer\n");
    printf("  cpuid            - CPUID monitor\n");
    printf("  cpuid-fake       - CPUID fake serial\n");
    printf("  hide [pid]       - Transparent mode (0=all)\n");
    printf("  events           - Show active events\n");
    printf("  clear            - Clear all events\n");
    printf("  sym <expr>       - Evaluate symbol/expression\n");
    printf("  pid <name>       - Find process PID by name\n");
    printf("  <HyperDbg cmd>   - Any HyperDbg command\n");
    printf("  quit / exit      - Unload and exit\n");
    printf("  help             - Show this help\n");
    printf("\n");
}

void
RunInteractiveLoop()
{
    char line[2048];

    printf("[+] Interactive mode. Type 'help' for commands, 'quit' to exit.\n\n");

    while (TRUE)
    {
        if (g_ShouldExit)
            break;

        printf("epthook> ");
        fflush(stdout);

        if (!fgets(line, sizeof(line), stdin))
        {
            printf("\n");
            break;
        }

        //
        // Trim trailing newline
        //
        size_t len = strlen(line);
        while (len > 0 && (line[len - 1] == '\n' || line[len - 1] == '\r'))
            line[--len] = '\0';

        if (len == 0)
            continue;

        //
        // Handle local commands
        //
        if (strcmp(line, "quit") == 0 || strcmp(line, "exit") == 0)
        {
            break;
        }
        else if (strcmp(line, "help") == 0)
        {
            ShowHelp();
            continue;
        }
        else if (strcmp(line, "test") == 0)
        {
            SetupEptHook_SimpleTest();
            continue;
        }
        else if (strncmp(line, "hook1", 5) == 0)
        {
            const char * pname = TARGET_PROCESS_NAME;
            char *       arg   = line + 5;
            while (*arg == ' ') arg++;
            if (*arg != '\0') pname = arg;
            UINT32 pid = FindProcessByName(pname);
            if (pid != 0)
                printf("[+] Found %s pid=0x%x\n", pname, pid);
            else
                printf("[!] Process %s not found, using strcmp filter\n", pname);
            SetupEptHook_IoctlRead(pname, pid);
            continue;
        }
        else if (strncmp(line, "hook2", 5) == 0)
        {
            const char * pname = TARGET_PROCESS_NAME;
            char *       arg   = line + 5;
            while (*arg == ' ') arg++;
            if (*arg != '\0') pname = arg;
            UINT32 pid = FindProcessByName(pname);
            SetupEptHook_FakeDiskSerial(pname, pid);
            continue;
        }
        else if (strncmp(line, "hook3", 5) == 0)
        {
            const char * pname = TARGET_PROCESS_NAME;
            char *       arg   = line + 5;
            while (*arg == ' ') arg++;
            if (*arg != '\0') pname = arg;
            UINT32 pid = FindProcessByName(pname);
            SetupEptHook_ModifyInputBuffer(pname, pid);
            continue;
        }
        else if (strcmp(line, "cpuid") == 0)
        {
            SetupCpuidHook_Monitor();
            continue;
        }
        else if (strcmp(line, "cpuid-fake") == 0)
        {
            SetupCpuidHook_FakeSerial();
            continue;
        }
        else if (strncmp(line, "hide", 4) == 0)
        {
            UINT32 pid = 0;
            char * arg = line + 4;
            while (*arg == ' ') arg++;
            if (*arg != '\0') pid = (UINT32)strtoul(arg, NULL, 0);
            SetupTransparentMode(pid);
            continue;
        }
        else if (strcmp(line, "events") == 0)
        {
            hyperdbg_u_run_command((CHAR *)"events");
            fflush(stdout);
            continue;
        }
        else if (strcmp(line, "clear") == 0)
        {
            hyperdbg_u_run_command((CHAR *)"events all clear");
            printf("[+] All events cleared\n");
            fflush(stdout);
            continue;
        }
        else if (strncmp(line, "sym ", 4) == 0)
        {
            char * expr = line + 4;
            while (*expr == ' ') expr++;
            if (*expr != '\0')
            {
                BOOLEAN hasError = FALSE;
                UINT64  addr    = EvalSymbol(expr, &hasError);
                if (!hasError)
                    printf("[+] %s = 0x%llx\n", expr, addr);
                else
                    printf("[-] Failed to evaluate: %s\n", expr);
            }
            fflush(stdout);
            continue;
        }
        else if (strncmp(line, "pid ", 4) == 0)
        {
            char * name = line + 4;
            while (*name == ' ') name++;
            UINT32 pid = FindProcessByName(name);
            if (pid != 0)
                printf("[+] %s pid = %u (0x%x)\n", name, pid, pid);
            else
                printf("[-] Process not found: %s\n", name);
            fflush(stdout);
            continue;
        }

        //
        // Pass through to HyperDbg command interpreter
        //
        INT ret = hyperdbg_u_run_command((CHAR *)line);
        fflush(stdout);

        //
        // ret == 1 means exit from debugger
        //
        if (ret == 1)
        {
            break;
        }
    }
}

// ============================================================
// Usage
// ============================================================

void
ShowUsage(const char * exe)
{
    printf("HyperDbg Hook Demo - EPT Hook + CPUID Fake\n");
    printf("\nUsage: %s [mode] [process_name]\n", exe);
    printf("\nModes:\n");
    printf("  1 = EPT hook + read IOCTL/buffer\n");
    printf("  2 = EPT hook + fake disk serial\n");
    printf("  3 = EPT hook + modify input buffer\n");
    printf("  4 = CPUID hook monitor\n");
    printf("  5 = CPUID hook fake serial\n");
    printf("  6 = Transparent mode (auto fake CPUID)\n");
    printf("  7 = Memory/Register API demo\n");
    printf("  8 = Simple EPT hook test (no filter)\n");
    printf("  (no args) = Interactive mode\n");
    printf("\nExamples:\n");
    printf("  %s                  - Interactive mode\n", exe);
    printf("  %s 1 notepad.exe    - EPT hook notepad.exe\n", exe);
    printf("  %s 8                - Simple EPT hook test\n", exe);
    printf("  %s 4                - CPUID monitor\n", exe);
    printf("\n");
}

int
main(int argc, char * argv[])
{
    SetConsoleOutputCP(CP_UTF8);

    //
    // 注册 Ctrl+C 处理程序（必须在 LoadHyperDbg 之前）
    //
    SetConsoleCtrlHandler(ConsoleCtrlHandler, TRUE);

    printf("=== HyperDbg Hook Demo ===\n\n");
    fflush(stdout);

    if (argc >= 2)
    {
        if (strcmp(argv[1], "-h") == 0 || strcmp(argv[1], "--help") == 0)
        {
            ShowUsage(argv[0]);
            return 0;
        }
    }

    if (LoadHyperDbg() != 0)
    {
        printf("[-] Load failed\n");
        return 1;
    }

    if (argc < 2)
    {
        //
        // Interactive mode - like HyperDbg CLI
        // Ctrl+C is handled by ConsoleCtrlHandler
        // Type 'quit' to exit
        //
        RunInteractiveLoop();
    }
    else
    {
        int mode = atoi(argv[1]);

        //
        // 拼接 argv[2..] 以支持含空格的进程名
        // 例如: epthook-demo.exe 1 SuperRecovery 7.0.exe
        //   argv[2]="SuperRecovery", argv[3]="7.0.exe"
        //   拼接为 "SuperRecovery 7.0.exe"
        //
        std::string pnameStr;
        if (argc >= 3)
        {
            pnameStr = argv[2];
            for (int i = 3; i < argc; i++)
            {
                pnameStr += " ";
                pnameStr += argv[i];
            }
        }
        else
        {
            pnameStr = TARGET_PROCESS_NAME;
        }
        const char * pname = pnameStr.c_str();

        printf("[*] Mode: %d, Process: %s\n\n", mode, pname);
        fflush(stdout);

        switch (mode)
        {
        case 1:
        {
            UINT32 pid = FindProcessByName(pname);
            if (pid != 0)
                printf("[+] Found %s pid=0x%x\n", pname, pid);
            else
                printf("[!] Process %s not found, using strcmp filter\n", pname);
            fflush(stdout);
            SetupEptHook_IoctlRead(pname, pid);
            break;
        }
        case 2:
        {
            UINT32 pid = FindProcessByName(pname);
            SetupEptHook_FakeDiskSerial(pname, pid);
            break;
        }
        case 3:
        {
            UINT32 pid = FindProcessByName(pname);
            SetupEptHook_ModifyInputBuffer(pname, pid);
            break;
        }
        case 4: SetupCpuidHook_Monitor(); break;
        case 5: SetupCpuidHook_FakeSerial(); break;
        case 6: SetupTransparentMode(0); break;
        case 7:
        {
            printf("[*] Memory/Register API demo\n");
            BOOLEAN hasError = FALSE;
            UINT64  addr     = EvalSymbol("nt!NtDeviceIoControlFile", &hasError);
            if (!hasError && addr != 0)
                printf("[+] nt!NtDeviceIoControlFile = 0x%llx\n", addr);
            else
                printf("[-] Symbol resolution failed\n");
            fflush(stdout);
            break;
        }
        case 8:
        {
            SetupEptHook_SimpleTest();
            break;
        }
        default:
            printf("[-] Unknown mode: %d\n", mode);
            ShowUsage(argv[0]);
            UnloadHyperDbg();
            return 1;
        }

        printf("\n[+] Active. Type 'quit' to stop.\n\n");
        fflush(stdout);

        //
        // Fall through to interactive loop so user can see output
        // and run additional commands
        //
        RunInteractiveLoop();
    }

    UnloadHyperDbg();
    return 0;
}
